# ──────────────────────────────────────────────
# Phase 1 — 필수
# ──────────────────────────────────────────────

# Database (Supabase)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ──────────────────────────────────────────────
# Phase 3 — 해당 Phase부터 필수
# ──────────────────────────────────────────────

# Redis (Upstash) — 선택. 없으면 캐시 없이 Prisma 직접 조회
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# Cron Job 인증 — Vercel Cron 요청 검증용 (openssl rand -base64 32 로 생성)
# CRON_SECRET=""

# Cloudinary
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ──────────────────────────────────────────────
# Phase 4 — 해당 Phase부터 필수
# ──────────────────────────────────────────────

# NextAuth
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET=""

# OAuth Providers
# KAKAO_CLIENT_ID=""
# KAKAO_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
